# YouTube Data API v3 key (free, get from Google Cloud Console)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Your server's public URL (needed for PubSubHubbub webhook callbacks)
# Example: https://yourdomain.com  (no trailing slash)
SERVER_URL=https://your-server-domain.com

# Path to the nlm CLI binary (run: which nlm)
NLM_PATH=/usr/local/bin/nlm
